{
  "expo": {
    "name": "NoteAll",
    "slug": "noteall",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.notesapp",
      "infoPlist": {
        "CFBundleDisplayName": "NoteAll"
      }
    },
    "android": {
      "package": "com.example.notesapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://noteall-seven.vercel.app"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
