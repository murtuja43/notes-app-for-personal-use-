# Base URL of the NoteAll backend (the Next.js web/API server).
#
# Default points at the production deployment so Expo Go works out of the box
# on any device/network.
#
# Local development alternatives (only if running the backend yourself):
#   - Android emulator:  http://10.0.2.2:3000   (10.0.2.2 maps to your computer's localhost)
#   - iOS simulator:     http://localhost:3000
#   - Physical device:   http://<your-computer-LAN-IP>:3000  (e.g. http://192.168.1.20:3000)
EXPO_PUBLIC_API_URL=https://noteall-seven.vercel.app
